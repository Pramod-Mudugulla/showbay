# ===========================================
# GitHub Repository Insights Service
# Environment Configuration
# ===========================================

# REQUIRED: PostgreSQL Database Connection
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/showbay_db

# OPTIONAL: GitHub Personal Access Token
# Increases rate limit from 60 to 5000 requests/hour
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=

# OPTIONAL: GitHub API Base URL (default: https://api.github.com)
# GITHUB_API_BASE_URL=https://api.github.com

# OPTIONAL: Timeout for GitHub API requests in seconds (default: 10)
# GITHUB_TIMEOUT_SECONDS=10
